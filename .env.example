# Copie para .env na raiz: copy .env.example .env

# ── Monólito DataGeo Digital (porta 3000) ────────────────────
APP_PORT=3000

# ── PostgreSQL DataGeo Digital (Prisma) ──────────────────────
CORE_POSTGRES_USER=postgres
CORE_POSTGRES_PASSWORD=postgres
CORE_POSTGRES_DB=soilsul_db
CORE_POSTGRES_PORT=5434
CORE_DATABASE_URL=postgresql://postgres:postgres@postgres-core:5432/soilsul_db

JWT_SECRET=altere_para_um_segredo_longo_aleatorio

# API geoespacial (mesmo origin)
NEXT_PUBLIC_GEO_API_URL=/api/geo
GEO_DATABASE_URL=postgresql://digitaltwin:change_me@localhost:5433/digital_twin

# ── PostGIS Digital Twin (opcional, profile geo no compose) ──
GEO_POSTGRES_USER=digitaltwin
GEO_POSTGRES_PASSWORD=change_me
GEO_POSTGRES_DB=digital_twin
GEO_POSTGRES_PORT=5433
GEO_DATABASE_URL=postgresql+asyncpg://digitaltwin:change_me@postgres-geo:5432/digital_twin

VITE_CESIUM_ION_TOKEN=
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# Sentinel-1 local (downloader)
SENTINEL_STORAGE_DIR=
# Opcional: só ficheiros .zip brutos (legado)
# SENTINEL1_DOWNLOAD_DIR=

# Copernicus Data Space (Sentinel-1 / OData + OAuth2)
COPERNICUS_USER=
COPERNICUS_PASSWORD=
# Opcional (predef.: cdse-public)
# COPERNICUS_OAUTH_CLIENT_ID=cdse-public
# COPERNICUS_ODATA_URL=https://catalogue.dataspace.copernicus.eu/odata/v1

# Copernicus / SNAP (opcional, api-geospatial)
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=

# ── IA interpretação geofísica (ERT / dipolo-dipolo) ─────────
# Refino regional (GeoSGB/CPRM + materiais ρ) e narrativa da secção invertida
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
