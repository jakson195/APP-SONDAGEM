{
  "name": "api-core",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start -p 3001",
    "lint": "eslint",
    "db:push": "dotenv -e ../.env -e .env.local -- prisma db push",
    "db:studio": "dotenv -e ../.env -e .env.local -- prisma studio",
    "db:seed": "dotenv -e ../.env -e .env.local -- npx tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.0",
    "bcrypt": "^6.0.0",
    "geotiff": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.4",
    "prisma": "6.19.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.34.5",
    "utm": "^1.1.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
