# ── PostgreSQL + PostGIS ─────────────────────────────────────
POSTGRES_USER=digitaltwin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=digital_twin
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# URL usada pelo backend (dentro do Docker: host = postgres)
DATABASE_URL=postgresql+asyncpg://digitaltwin:change_me_in_production@postgres:5432/digital_twin

# ── Backend FastAPI ──────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=500
LAS_MAX_UPLOAD_MB=2048
PUBLIC_API_URL=http://localhost:8000

# Copernicus Data Space (Sentinel-1) — opcional
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=
COPERNICUS_ODATA_URL=https://catalogue.dataspace.copernicus.eu/odata/v1
INSAR_MAX_SCENES=12

# SNAP GPT (processamento InSAR real) — opcional
SNAP_GPT_PATH=
SNAP_INSAR_GRAPH_PATH=

# ── Frontend Vite (build-time / dev) ─────────────────────────
VITE_API_URL=http://localhost:8000
VITE_CESIUM_ION_TOKEN=

# ── Cesium (opcional — Ion para terrain/imagery) ─────────────
CESIUM_ION_TOKEN=
