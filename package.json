{
  "name": "app-sondagem",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:prisma": "prisma generate && next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "db:up": "docker compose up -d",
    "db:push": "dotenv -e .env.local -e .env -- prisma db push",
    "db:studio": "dotenv -e .env.local -e .env -- prisma studio",
    "db:validate": "dotenv -e .env.local -e .env -- prisma validate",
    "db:sync": "npm run db:push && prisma generate",
    "db:seed": "dotenv -e .env.local -e .env -- npx tsx prisma/seed.ts",
    "android:live": "npx cap run android -l --host=localhost --port=3000 --forwardPorts 3000:3000",
    "vercel": "vercel",
    "verce": "vercel",
    "vercel:prod": "vercel --prod",
    "vercel:pull": "vercel env pull .env.local"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@prisma/client": "6.19.0",
    "@react-google-maps/api": "^2.20.8",
    "@react-pdf/renderer": "^4.5.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "autoprefixer": "^10.5.0",
    "bcrypt": "^6.0.0",
    "geotiff": "^3.0.5",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "pdfjs-dist": "^5.7.284",
    "postcss": "^8.5.14",
    "prisma": "6.19.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "three": "^0.184.0",
    "utm": "^1.1.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/google.maps": "^3.64.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vercel": "^53.1.1"
  }
}
