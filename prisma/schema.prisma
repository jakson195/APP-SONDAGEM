generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/** Controlo global da plataforma (SUPER_ADMIN / MASTER_ADMIN legado). */
enum SystemRole {
  MASTER_ADMIN
  SUPER_ADMIN
  USER
}

/** Papel do utilizador dentro de uma empresa (equipa / permissões de negócio). */
enum OrgRole {
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

/** Estado de assinatura (extensível para billing). */
enum SubscriptionStatus {
  ACTIVE
  TRIAL
  SUSPENDED
  CANCELLED
}

/** Ciclo de vida da obra (projeto de campo). */
enum ObraStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

model User {
  id         Int        @id @default(autoincrement())
  email      String     @unique
  password   String
  name       String?
  systemRole SystemRole @default(USER)

  companies   Company[]
  memberships OrgMembership[]
}

/**
 * Empresa na plataforma (tabela física `empresa`).
 * Modelo `Company` para alinhar com nomenclatura multi-tenant SaaS.
 */
model Company {
  id     Int  @id @default(autoincrement())
  name   String @map("nome")
  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  plan   String?              @map("planSlug")
  status SubscriptionStatus @default(ACTIVE) @map("subscriptionStatus")

  cnpj    String? @unique
  phone   String?
  email   String?
  address String?
  logo    String?
  createdAt DateTime @default(now())

  obras       Obra[]
  equipes     Equipe[]
  memberships OrgMembership[]
  modulos     EmpresaModulo[]

  @@map("Empresa")
}

/** Equipa operacional dentro da empresa (alocação de campo / projetos). */
model Equipe {
  id        Int     @id @default(autoincrement())
  nome      String
  empresaId Int     @map("empresaId")
  company   Company @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  memberships OrgMembership[]
}

/**
 * Utilizador ↔ empresa (e opcionalmente equipe).
 * Um utilizador pode pertencer a várias empresas com papéis distintos.
 */
model OrgMembership {
  id        Int     @id @default(autoincrement())
  userId    Int
  empresaId Int     @map("empresaId")
  equipeId  Int?
  orgRole   OrgRole @default(MEMBER)
  /**
   * Módulos explícitos (chaves de `modulos-plataforma.ts`). Lista vazia = acede a
   * todos os módulos ativos na empresa. Caso contrário, apenas a interseção.
   */
  modulosPermitidos String[] @default([])

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  equipe  Equipe? @relation(fields: [equipeId], references: [id], onDelete: SetNull)

  @@unique([userId, empresaId])
}

/** Módulos da app ligados por chave (`lib/modulos-plataforma.ts`). */
model EmpresaModulo {
  id        Int     @id @default(autoincrement())
  empresaId Int     @map("empresaId")
  modulo    String
  ativo     Boolean @default(true)

  company Company @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([empresaId, modulo])
}

model Obra {
  id        Int     @id @default(autoincrement())
  nome      String
  cliente   String
  local     String
  /** Notas internas / âmbito do projeto */
  description String?
  status    ObraStatus @default(ACTIVE)
  /** WGS84 graus decimais (opcional), para Google Maps */
  latitude  Float?
  longitude Float?
  /** Empresa proprietária (multi-tenant) — coluna física `empresaId`. */
  companyId Int        @map("empresaId")
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  furos          Furo[]
  projectModules ProjectModule[]
  vesProjects    VESProject[]
}

/** Módulos ativados por obra (projeto de campo). */
model ProjectModule {
  id        Int     @id @default(autoincrement())
  projectId Int     @map("projectId")
  module    String
  active    Boolean @default(true)
  project   Obra    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, module])
  @@map("ProjectModule")
}

model Furo {
  id     Int    @id @default(autoincrement())
  codigo String
  /** spt | rotativa | trado | piezo — coluna SQLite: `tipoCampo` (@map). */
  tipo      String @default("spt") @map("tipoCampo")
  obraId    Int
  latitude  Float?
  longitude Float?

  obra Obra @relation(fields: [obraId], references: [id], onDelete: Cascade)

  /** Grelhas, meta de PDF, fotos, etc. (módulos que não usam só a tabela `SPT`). */
  dadosCampo Json?

  spt SPT[]
}

model SPT {
  id     Int   @id @default(autoincrement())
  prof   Float
  g1     Int
  g2     Int
  g3     Int
  /** Penetração observada no intervalo (cm), ex.: 2 golpes / 17 cm. */
  cm1    Int   @default(15)
  cm2    Int   @default(15)
  cm3    Int   @default(15)
  solo   String
  furoId Int
  furo   Furo  @relation(fields: [furoId], references: [id])
}

model VESProject {
  id        Int      @id @default(autoincrement())
  nome      String
  metodo    String
  payload   Json
  projectId Int?
  project   Obra?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, nome])
}
